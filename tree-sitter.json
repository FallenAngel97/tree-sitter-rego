{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "rego",
      "camelcase": "Rego",
      "title": "Rego",
      "scope": "source.rego",
      "file-types": [
        "rego"
      ],
      "injection-regex": "^rego$",
      "class-name": "TreeSitterRego"
    }
  ],
  "metadata": {
    "version": "1.1.0",
    "license": "MIT",
    "description": "Rego, the policy language used by Open Policy Agent (OPA)",
    "authors": [
      {
        "name": "FallenAngel97"
      }
    ],
    "links": {
      "repository": "https://github.com/FallenAngel97/tree-sitter-rego"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
